# ====================================
# AUTHENTICATION / SECURITY
# ====================================
# Strong, random secret for signing JWTs
JWT_SECRET=8f2b3d7c-4e91-4a2f-9a5e-1d6c2b7f3e9a

# Access tokens expire quickly (15 minutes)
JWT_EXPIRES_IN=15m

# Refresh tokens last longer (30 days)
REFRESH_TOKEN_DAYS=30

# Password hashing strength
SALT_ROUNDS=12

# Admin registration safeguard
ADMIN_SECRET=AdminOnly$Gate987

# Enforce secure cookies and rotation
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
ROTATE_REFRESH_TOKENS=true


# ====================================
# FRONTEND / CORS
# ====================================
